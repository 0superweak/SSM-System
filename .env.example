# Use a Supabase publishable/anon key. Never place an sb_secret or service-role
# key in this file or in a desktop build.
SSM_SUPABASE_URL=https://your-project.supabase.co
SSM_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Administration scripts only. Do not configure this on application PCs.
# SSM_SUPABASE_SERVICE_KEY=your-secret-service-role-key
